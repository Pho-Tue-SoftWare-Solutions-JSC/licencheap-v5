  "10": {
    "name": "Cpanel",
    "display_name": "cPanel",
    "api_type": "Cpanel",
    "installer_arg": "cPanel",
    "command_alias": "CP",
    "verify_command": "touch /etc/.verifylicense ; {{update_command}}",
    "notes": [
      "Softaculous, SitePad and FleetSSL licenses that come free with a cPanel license renew together with cPanel.",
      "Changing cPanel IP may also update bundled Softaculous, SitePad and FleetSSL licenses."
    ],
    "extra_commands": [
      {
        "title": "Activate FleetSSL",
        "command": "{{update_command}} -fleetssl"
      }
    ]
